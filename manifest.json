{
  "manifest_version": 3,
  "name": "Nova Driving Range",
  "version": "1.0",
  "description": "Nova Driving Range — 3D driving range overlay for your launch monitor.",
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://dashboard.openlaunch.io/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://dashboard.openlaunch.io/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Nova Driving Range",
    "default_popup": ""
  },
  "web_accessible_resources": [
    {
      "resources": ["three.min.js", "sounds.js", "scene.js", "fonts/LexendDeca-Bold.ttf", "sonic.wav", "driver.mp3", "irons.mp3", "background.mp3", "wind.mp3", "report.html", "report.js"],
      "matches": ["https://dashboard.openlaunch.io/*"]
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
